#!/usr/bin/env bash

# Ensure PATH includes common locations for bash 4+, python3, etc.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Load config with fallback
source /etc/lldpq.conf 2>/dev/null || true
LLDPQ_DIR="${LLDPQ_DIR:-$HOME/lldpq}"

cd "$LLDPQ_DIR"
wait_until_not_running() {
    script_name="$1"
    while pgrep -f "$script_name" >/dev/null; do
        sleep 10
    done
}
wait_until_not_running "get-configs.sh"
./get-configs.sh >/dev/null 2>&1
exit 0
